name: student-learning-classifier

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path:
        type: str
        default: namadataset_preprocessing/student_cleaned.csv
      epochs:
        type: int
        default: 20
      batch_size:
        type: int
        default: 64
      learning_rate:
        type: float
        default: 0.001
      hidden_units:
        type: int
        default: 64
      dropout:
        type: float
        default: 0.2
    command: >-
      python modelling.py
      --data-path {data_path}
      --epochs {epochs}
      --batch-size {batch_size}
      --learning-rate {learning_rate}
      --hidden-units {hidden_units}
      --dropout {dropout}
      --verbose 0
